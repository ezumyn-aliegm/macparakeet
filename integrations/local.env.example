# Copy to the repo root as `.env.local` (gitignored) and customize for your LAN.
#
# These variables are read at app runtime via the process environment.
# For GUI launches from Finder, set Ollama base URL in Settings instead,
# or launch from a shell that exports these vars.

# Ollama host on your home LAN (example placeholder — replace with your server IP)
OLLAMA_DEFAULT_HOST=192.168.1.100

# IPv4 prefix that counts as "home LAN" for Ollama availability checks
OLLAMA_LAN_PREFIX=192.168.1.

# Optional: force Ollama base URL regardless of LAN detection
# OLLAMA_HOST=http://192.168.1.100:11434